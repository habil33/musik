<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MV Music Player</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:black;
overflow:hidden;
}

/* ===== BG IMAGE ===== */
.bg{
position:absolute;
width:100%;
height:100%;
background:url("bg.jpg") center/cover no-repeat;

/* 🔥 light cinematic blur */
filter:blur(4px) brightness(0.55) contrast(1.1);
transform:scale(1.05);
z-index:0;
}

/* ===== BG VIDEO ===== */
#bg-video{
position:absolute;
width:100%;
height:100%;
object-fit:cover;
z-index:0;

/* 🔥 light blur */
filter:blur(3px) brightness(0.55) contrast(1.1);
transform:scale(1.05);
display:none;
}

/* smooth transition MV */
.bg,
#bg-video{
transition:opacity 0.8s ease, transform 1s ease;
}

/* FRAME */
.frame{
position:relative;
width:360px;
height:640px;
display:flex;
justify-content:center;
align-items:center;
z-index:2;
}

/* PLAYER BOX */
.player-box{
width:200px;
background:rgba(0,0,0,0.4);
backdrop-filter:blur(8px);
border-radius:15px;
padding:15px;
border:1px solid rgba(255,255,255,0.1);
position:relative;
z-index:3;
}

/* COVER */
.cover{
width:100%;
height:140px;
border-radius:12px;
background-size:cover;
background-position:center;
}

/* TITLE */
h2{
color:white;
font-size:16px;
text-align:center;
margin-top:8px;
}

/* VISUALIZER */
canvas{
width:100%;
height:60px;
opacity:0.5;
margin-top:8px;
}

/* CONTROLS */
.controls{
display:flex;
justify-content:center;
gap:6px;
margin-top:10px;
}

button{
padding:6px 8px;
font-size:12px;
border:none;
background:rgba(255,255,255,0.1);
color:white;
border-radius:6px;
cursor:pointer;
}

/* ===== REAL VINYL BACK ===== */
.vinyl{
position:absolute;
width:260px;
height:260px;
border-radius:50%;
top:50%;
left:50%;
transform:translate(-50%,-50%) scale(1.2);

/* vinyl base */
background:
radial-gradient(circle at center,
#1a1a1a 0%,
#000 45%,
#0a0a0a 70%,
#000 100%);

/* groove */
background-image:
repeating-radial-gradient(
circle,
rgba(255,255,255,0.07) 0px,
rgba(255,255,255,0.07) 1px,
transparent 2px,
transparent 5px
);

/* depth */
box-shadow:
inset 0 0 25px rgba(255,255,255,0.08),
inset 0 0 60px rgba(0,0,0,0.9),
0 0 30px rgba(0,0,0,0.8);

animation:spin 4s linear infinite;

opacity:0;
transition:0.6s ease;

z-index:1;
}

.vinyl.active{
opacity:0.85;
}

/* CENTER LABEL */
.vinyl::after{
content:"";
position:absolute;
width:55px;
height:55px;
background:
radial-gradient(circle,
#555 0%,
#111 60%,
#000 100%);
border-radius:50%;
top:50%;
left:50%;
transform:translate(-50%,-50%);
}

/* SPIN */
@keyframes spin{
from{transform:translate(-50%,-50%) rotate(0deg) scale(1.2);}
to{transform:translate(-50%,-50%) rotate(360deg) scale(1.2);}
}
</style>
</head>

<body>

<!-- BACKGROUND -->
<div class="bg" id="bg-image"></div>
<video id="bg-video" autoplay muted loop></video>

<div class="frame">

<!-- VINYL BACK -->
<div class="vinyl" id="vinyl"></div>

<!-- PLAYER FRONT -->
<div class="player-box">

<div class="cover" id="cover"></div>
<h2 id="title">Music</h2>

<canvas id="visualizer"></canvas>

<div class="controls">
<button onclick="prev()">Prev</button>
<button onclick="play()">Play</button>
<button onclick="pause()">Pause</button>
<button onclick="next()">Next</button>
</div>

</div>

</div>

<audio id="audio"></audio>

<script>

/* SONG DATA */
const songs=[
{
title:"Into It",
file:"intoit.mp3",
cover:"cover1.jpg",
bgType:"image"
},
{
title:"The Walls",
file:"thewalls.mp3",
cover:"cover2.jpg",
bgType:"image"
},
{
title:"Consume",
file:"consume.mp3",
cover:"cover3.jpg",
bgType:"video",
bg:"bg.mp4"
}
];

let i=0;

const audio=document.getElementById("audio");
const cover=document.getElementById("cover");
const title=document.getElementById("title");
const vinyl=document.getElementById("vinyl");
const bgImage=document.getElementById("bg-image");
const bgVideo=document.getElementById("bg-video");

/* LOAD SONG + BG SWITCH */
function loadSong(x){
audio.src=songs[x].file;
cover.style.backgroundImage=`url('${songs[x].cover}')`;
title.innerText=songs[x].title;

/* BACKGROUND SWITCH */
if(songs[x].bgType==="video"){
bgVideo.style.display="block";
bgVideo.src=songs[x].bg;
bgVideo.play();

bgImage.style.display="none";
}else{
bgVideo.style.display="none";
bgVideo.pause();

bgImage.style.display="block";
bgImage.style.backgroundImage="url('bg.jpg')";
}
}

/* VINYL */
function showVinyl(){
vinyl.classList.add("active");
}

function hideVinyl(){
vinyl.classList.remove("active");
}

/* VISUALIZER */
let ctx, analyser, source, dataArray, canvas, c;

function initVisualizer(){
canvas=document.getElementById("visualizer");
c=canvas.getContext("2d");

ctx=new (window.AudioContext||window.webkitAudioContext)();
analyser=ctx.createAnalyser();

source=ctx.createMediaElementSource(audio);
source.connect(analyser);
analyser.connect(ctx.destination);

analyser.fftSize=64;
dataArray=new Uint8Array(analyser.frequencyBinCount);

draw();
}

function draw(){
requestAnimationFrame(draw);

analyser.getByteFrequencyData(dataArray);

c.clearRect(0,0,canvas.width,canvas.height);

let x=0;

for(let i=0;i<dataArray.length;i++){
let h=dataArray[i]/2;

c.fillStyle="rgba(180,180,180,0.4)";
c.fillRect(x,30-h/2,4,h);

x+=6;
}
}

/* CONTROLS */
function play(){
audio.play();
if(!ctx) initVisualizer();
showVinyl();
}

function pause(){
audio.pause();
hideVinyl();
}

function next(){
i++;
if(i>=songs.length) i=0;
loadSong(i);
play();
}

function prev(){
i--;
if(i<0) i=songs.length-1;
loadSong(i);
play();
}

/* INIT */
loadSong(i);

</script>

</body>
</html>
